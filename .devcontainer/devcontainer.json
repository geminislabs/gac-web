{
	"name": "gac-web",
	"image": "mcr.microsoft.com/devcontainers/javascript-node:22",
	"forwardPorts": [5173],
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"svelte.svelte-vscode",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"editorconfig.editorconfig"
			]
		}
	}
}
