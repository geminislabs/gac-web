{
	"name": "geminislabs-admin-control",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:unit": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"validate": "npm run lint && npm run check && npm run test:coverage && npm run build",
		"commitlint": "commitlint",
		"audit": "npm audit --audit-level=high",
		"scan:secrets": "bash scripts/gitleaks-scan.sh",
		"scan:osv": "bash scripts/osv-scan.sh"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.1",
		"@vitest/coverage-v8": "^3.2.4",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@eslint/js": "^9.39.1",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22.12.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"happy-dom": "^20.0.7",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.43.8",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.3",
		"vite": "^7.2.2",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@googlemaps/js-api-loader": "^1.16.10",
		"@googlemaps/markerclusterer": "^2.6.2"
	},
	"overrides": {
		"cookie": "^0.7.0",
		"esbuild": ">=0.28.1",
		"js-yaml": ">=4.2.0"
	}
}
